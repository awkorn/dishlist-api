generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  uid         String        @id
  email       String        @unique
  username    String?       @unique
  firstName   String?
  lastName    String?
  bio         String?
  avatarUrl   String?
  role        UserRole      @default(USER)
  status      AccountStatus @default(ACTIVE)
  suspendedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  ownedDishLists    DishList[]             @relation("DishListOwner")
  collaboratedLists DishListCollaborator[]
  followedDishLists DishListFollower[]
  createdRecipes    Recipe[]               @relation("RecipeCreator")
  sharedRecipes     RecipeShare[]          @relation("RecipeShareSender")
  receivedRecipes   RecipeShare[]          @relation("RecipeShareRecipient")
  addedRecipes      DishListRecipe[]       @relation("UserAddedRecipes")
  pinnedDishLists   UserDishListPin[]

  // User following relationships
  followers UserFollow[] @relation("UserFollowers")
  following UserFollow[] @relation("UserFollowing")

  // User blocking relationships
  blockedUsers UserBlock[] @relation("UserBlocksMade")
  blockedBy    UserBlock[] @relation("UserBlocksReceived")

  // Notifications
  sentNotifications     Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationReceiver")

  // DishList Invites
  sentInvites     DishListInvite[] @relation("InviteSender")
  receivedInvites DishListInvite[] @relation("InviteReceiver")

  // Push tokens
  pushTokens PushToken[]

  // Social media recipe imports
  recipeImports RecipeImport[]

  // Moderation
  submittedReports  ContentReport[]    @relation("ReportsSubmitted")
  receivedReports   ContentReport[]    @relation("ReportsReceived")
  assignedReports   ContentReport[]    @relation("ReportsAssigned")
  resolvedReports   ContentReport[]    @relation("ReportsResolved")
  moderationActions ModerationAction[] @relation("ModerationActionsPerformed")

  @@index([status])
  @@index([role])
  // Trigram GIN indexes accelerate the ILIKE substring filters used by search.
  @@index([username(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("User")
}

// Durable tombstone for account deletion. This intentionally has no foreign
// key to User so it survives deletion and blocks stale JWTs from recreating an
// account if an external Supabase cleanup step needs to be retried.
model AccountDeletion {
  userId      String    @id
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  lastError   String?

  @@map("AccountDeletion")
}

model ContentReport {
  id             String               @id @default(cuid())
  targetType     ModerationTargetType
  targetId       String
  reason         ContentReportReason
  details        String?
  status         ContentReportStatus  @default(PENDING)
  dedupeKey      String?              @unique
  targetSnapshot Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  reviewedAt     DateTime?
  resolvedAt     DateTime?
  resolutionNote String?

  reporterId String
  reporter   User   @relation("ReportsSubmitted", fields: [reporterId], references: [uid], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("ReportsReceived", fields: [ownerId], references: [uid], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("ReportsAssigned", fields: [assignedToId], references: [uid], onDelete: SetNull)

  resolvedById String?
  resolvedBy   User?   @relation("ReportsResolved", fields: [resolvedById], references: [uid], onDelete: SetNull)

  actions ModerationAction[]

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([reporterId])
  @@index([ownerId])
  @@index([assignedToId])
  @@map("ContentReport")
}

model ModerationAction {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String
  action     ModerationActionType
  note       String
  metadata   Json?
  createdAt  DateTime             @default(now())

  reportId String?
  report   ContentReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  moderatorId String?
  moderator   User?   @relation("ModerationActionsPerformed", fields: [moderatorId], references: [uid], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([reportId])
  @@index([moderatorId, createdAt])
  @@map("ModerationAction")
}

model ModerationReview {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String?
  userId     String?
  provider   String
  model      String
  inputType  ModerationInputType
  status     ModerationStatus
  categories Json?
  scores     Json?
  reason     String?
  createdAt  DateTime             @default(now())

  @@index([targetType, targetId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("ModerationReview")
}

model DishList {
  id              String                 @id @default(cuid())
  title           String
  visibility      DishListVisibility     @default(PUBLIC)
  isDefault       Boolean                @default(false)
  moderationState ContentModerationState @default(VISIBLE)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  // Owner relation
  ownerId String
  owner   User   @relation("DishListOwner", fields: [ownerId], references: [uid], onDelete: Cascade)

  // Relations
  recipes       DishListRecipe[]
  collaborators DishListCollaborator[]
  followers     DishListFollower[]
  invites       DishListInvite[]
  pins          UserDishListPin[]

  @@index([moderationState])
  @@index([ownerId])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("DishList")
}

model Recipe {
  id               String                 @id @default(cuid())
  title            String
  description      String?
  instructions     Json // Changed from String[] - now stores RecipeItem[]
  ingredients      Json // Changed from String[] - now stores RecipeItem[]
  prepTime         Int? // minutes
  cookTime         Int? // minutes
  servings         Int?
  imageUrl         String?
  imageUrls        String[]               @default([])
  nutrition        Json?
  notes            String[]               @default([])
  tags             String[]               @default([])
  originalRecipeId String? // For tracking copied recipes
  // Social-import provenance: link back to the original post + visible
  // attribution (App Review posture — we store extracted text, never media).
  sourceUrl        String?
  sourcePlatform   SocialPlatform?
  sourceAuthor     String? // e.g. "@halfbakedharvest"
  moderationState  ContentModerationState @default(VISIBLE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  // Creator relation
  creatorId String
  creator   User   @relation("RecipeCreator", fields: [creatorId], references: [uid], onDelete: Cascade)

  // Relations
  dishLists DishListRecipe[]
  shares    RecipeShare[]
  imports   RecipeImport[]

  // Self-reference for original recipe tracking
  originalRecipe Recipe?  @relation("RecipeCopies", fields: [originalRecipeId], references: [id])
  copies         Recipe[] @relation("RecipeCopies")

  @@unique([creatorId, originalRecipeId])
  @@index([moderationState])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("Recipe")
}

model RecipeShare {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  sharedById String
  sharedBy   User   @relation("RecipeShareSender", fields: [sharedById], references: [uid], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("RecipeShareRecipient", fields: [recipientId], references: [uid], onDelete: Cascade)

  @@unique([recipeId, recipientId])
  @@index([recipientId])
  @@map("RecipeShare")
}

model DishListRecipe {
  id      String   @id @default(cuid())
  addedAt DateTime @default(now())

  // Relations
  dishListId String
  dishList   DishList @relation(fields: [dishListId], references: [id], onDelete: Cascade)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Who added this recipe to the dish list
  addedById String?
  addedBy   User?   @relation("UserAddedRecipes", fields: [addedById], references: [uid], onDelete: SetNull)

  @@unique([dishListId, recipeId])
  @@map("DishListRecipe")
}

model DishListCollaborator {
  id        String   @id @default(cuid())
  invitedAt DateTime @default(now())

  // Relations
  dishListId String
  dishList   DishList @relation(fields: [dishListId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@unique([dishListId, userId])
  @@index([userId])
  @@map("DishListCollaborator")
}

model DishListFollower {
  id         String   @id @default(cuid())
  followedAt DateTime @default(now())

  // Relations
  dishListId String
  dishList   DishList @relation(fields: [dishListId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@unique([dishListId, userId])
  @@index([userId])
  @@map("DishListFollower")
}

model UserDishListPin {
  id       String   @id @default(cuid())
  pinnedAt DateTime @default(now())

  // Relations
  dishListId String
  dishList   DishList @relation(fields: [dishListId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@unique([dishListId, userId])
  @@index([userId])
  @@map("UserDishListPin")
}

model DishListInvite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid()) // Secure token for invite URLs
  expiresAt DateTime // 7 days from creation
  usedAt    DateTime? // Timestamp when accepted (null if pending)
  createdAt DateTime  @default(now())

  // Relations
  dishListId String
  dishList   DishList @relation(fields: [dishListId], references: [id], onDelete: Cascade)

  inviterId String
  inviter   User   @relation("InviteSender", fields: [inviterId], references: [uid], onDelete: Cascade)

  // For link invites: inviteeId is null (anyone with link can use)
  // For direct invites: inviteeId is set (only that user can use)
  inviteeId String?
  invitee   User?   @relation("InviteReceiver", fields: [inviteeId], references: [uid], onDelete: Cascade)

  @@index([token])
  @@index([dishListId])
  @@index([inviteeId])
  @@index([expiresAt])
  @@map("DishListInvite")
}

model UserFollow {
  id         String       @id @default(cuid())
  status     FollowStatus @default(PENDING)
  followedAt DateTime     @default(now())
  acceptedAt DateTime?

  // Relations
  followerId String
  follower   User   @relation("UserFollowing", fields: [followerId], references: [uid], onDelete: Cascade)

  followingId String
  following   User   @relation("UserFollowers", fields: [followingId], references: [uid], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, status, acceptedAt, id])
  @@index([followerId, status, acceptedAt, id])
  @@map("UserFollow")
}

model UserBlock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerId String
  blocker   User   @relation("UserBlocksMade", fields: [blockerId], references: [uid], onDelete: Cascade)

  blockedId String
  blocked   User   @relation("UserBlocksReceived", fields: [blockedId], references: [uid], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("UserBlock")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      String? // JSON string for additional data
  createdAt DateTime         @default(now())

  // Relations
  senderId String?
  sender   User?   @relation("NotificationSender", fields: [senderId], references: [uid], onDelete: SetNull)

  receiverId String
  receiver   User   @relation("NotificationReceiver", fields: [receiverId], references: [uid], onDelete: Cascade)

  @@index([receiverId, createdAt])
  @@index([receiverId, isRead])
  @@index([senderId])
  @@map("Notification")
}

// One row per (user, canonical post URL) social-media import attempt. Doubles
// as the idempotency guard (re-sharing the same post reuses the row) and the
// status record the app polls. Processing is in-process fire-and-forget, so a
// server restart can strand PENDING/PROCESSING rows — the status GET applies a
// staleness backstop and FAILED rows are retried by re-sharing.
model RecipeImport {
  id           String             @id @default(cuid())
  sourceUrl    String // as shared by the user
  canonicalUrl String // normalized: tracking params stripped, short links resolved
  platform     SocialPlatform
  status       RecipeImportStatus @default(PENDING)
  errorCode    String? // SCRAPE_FAILED | PRIVATE_POST | NO_RECIPE_FOUND | VIDEO_TOO_LONG | MODERATION_BLOCKED | TIMEOUT | INTERNAL
  errorMessage String? // user-displayable
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([userId, canonicalUrl])
  @@index([userId, createdAt])
  @@map("RecipeImport")
}

model PushToken {
  id        String   @id @default(cuid())
  token     String // Expo push token (ExponentPushToken[...])
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@unique([userId, token])
  @@map("PushToken")
}

// Enums
enum DishListVisibility {
  PUBLIC
  PRIVATE
}

enum NotificationType {
  DISHLIST_INVITATION
  DISHLIST_SHARED
  RECIPE_SHARED
  RECIPE_ADDED
  DISHLIST_FOLLOWED
  COLLABORATION_ACCEPTED
  COLLABORATION_DECLINED
  USER_FOLLOWED
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  SYSTEM_UPDATE
  REPORT_RESOLVED
  RECIPE_IMPORT_COMPLETED
  RECIPE_IMPORT_FAILED
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  FACEBOOK
}

enum RecipeImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum ContentModerationState {
  VISIBLE
  HIDDEN
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

enum ModerationTargetType {
  USER
  DISHLIST
  RECIPE
  IMAGE
}

enum ModerationInputType {
  TEXT
  IMAGE
}

enum ModerationStatus {
  APPROVED
  REJECTED
  ERROR
}

enum ContentReportReason {
  INAPPROPRIATE
  HARASSMENT
  SPAM
  OTHER
}

enum ContentReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

enum ModerationActionType {
  CLAIM
  DISMISS_REPORT
  HIDE_CONTENT
  SUSPEND_USER
  RESTORE_CONTENT
  RESTORE_USER
}
